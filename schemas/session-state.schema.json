{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codexus.local/schemas/session-state.schema.json",
  "title": "Codexus Session State",
  "type": "object",
  "required": ["schemaVersion", "sessionId", "cwd", "status", "createdAt", "updatedAt", "lastCommand", "checkpoints", "verifications", "lastVerifiedFingerprint", "hookEvents", "subagents", "linkedRunIds", "capabilities", "notifyDispatch", "overlays"],
  "properties": {
    "schemaVersion": { "const": 4 },
    "sessionId": { "type": "string", "minLength": 1 },
    "cwd": { "type": "string", "minLength": 1 },
    "status": { "enum": ["initialized"] },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "lastCommand": { "type": ["string", "null"] },
    "checkpoints": { "type": "array", "items": { "type": "object" } },
    "verifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "createdAt", "status", "commands", "path", "artifactsDir", "workspaceFingerprint"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "createdAt": { "type": "string" },
          "status": { "type": "string", "minLength": 1 },
          "commands": { "type": "array", "items": { "type": "string" } },
          "path": { "type": "string", "minLength": 1 },
          "artifactsDir": { "type": "string", "minLength": 1 },
          "workspaceFingerprint": {
            "type": ["object", "null"],
            "required": ["schemaVersion", "isGit", "head", "stagedDiffHash", "unstagedDiffHash", "untracked", "cwd", "computedAt", "degraded", "degradedReason"],
            "properties": {
              "schemaVersion": { "const": 1 },
              "isGit": { "type": "boolean" },
              "head": { "type": ["string", "null"] },
              "stagedDiffHash": { "type": ["string", "null"] },
              "unstagedDiffHash": { "type": ["string", "null"] },
              "untracked": {
                "type": "object",
                "required": ["hash", "count", "partial"],
                "properties": {
                  "hash": { "type": "string", "minLength": 1 },
                  "count": { "type": "number" },
                  "partial": { "type": "boolean" }
                }
              },
              "cwd": { "type": "string", "minLength": 1 },
              "computedAt": { "type": "string" },
              "degraded": { "type": "boolean" },
              "degradedReason": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "lastVerifiedFingerprint": {
      "type": ["object", "null"],
      "required": ["verificationId", "status", "recordedAt", "fingerprint"],
      "properties": {
        "verificationId": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "recordedAt": { "type": "string" },
        "fingerprint": {
          "type": "object",
          "required": ["schemaVersion", "isGit", "head", "stagedDiffHash", "unstagedDiffHash", "untracked", "cwd", "computedAt", "degraded", "degradedReason"],
          "properties": {
            "schemaVersion": { "const": 1 },
            "isGit": { "type": "boolean" },
            "head": { "type": ["string", "null"] },
            "stagedDiffHash": { "type": ["string", "null"] },
            "unstagedDiffHash": { "type": ["string", "null"] },
            "untracked": {
              "type": "object",
              "required": ["hash", "count", "partial"],
              "properties": {
                "hash": { "type": "string", "minLength": 1 },
                "count": { "type": "number" },
                "partial": { "type": "boolean" }
              }
            },
            "cwd": { "type": "string", "minLength": 1 },
            "computedAt": { "type": "string" },
            "degraded": { "type": "boolean" },
            "degradedReason": { "type": ["string", "null"] }
          }
        }
      }
    },
    "hookEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "event", "observedAt", "source", "cwd", "runtimeSurface", "process"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "event": { "type": "string", "minLength": 1 },
          "observedAt": { "type": "string" },
          "source": { "enum": ["notify"] },
          "cwd": { "type": "string" },
          "runtimeSurface": { "enum": ["unknown", "cli-tui", "desktop-app-server"] },
          "process": {
            "type": "object",
            "required": ["pid", "ppid", "cwd", "bundleIdentifier"],
            "properties": {
              "pid": { "type": "number" },
              "ppid": { "type": "number" },
              "cwd": { "type": "string" },
              "bundleIdentifier": { "type": ["string", "null"] }
            }
          },
          "heartbeatEvidence": { "type": ["object", "null"] }
        }
      }
    },
    "subagents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["taskId", "role", "status", "recordedAt", "path", "claimCount", "limitationCount", "evidenceLinks"],
        "properties": {
          "taskId": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "status": { "enum": ["recorded", "attached"] },
          "recordedAt": { "type": "string" },
          "path": { "type": "string", "minLength": 1 },
          "claimCount": { "type": "number" },
          "limitationCount": { "type": "number" },
          "evidenceLinks": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "linkedRunIds": { "type": "array", "items": { "type": "string" } },
    "capabilities": {
      "type": "object",
      "required": ["tmux", "hooks", "statusline"],
      "properties": {
        "tmux": { "enum": ["available", "unavailable"] },
        "hooks": { "enum": ["available", "configured", "unavailable"] },
        "statusline": { "enum": ["available", "unavailable"] }
      }
    },
    "notifyDispatch": {
      "type": "object",
      "required": ["status", "lastTurnEndedAt", "lastObservedAt", "runtimeSurface", "caveat"],
      "properties": {
        "status": { "enum": ["observed", "unobserved", "not_configured"] },
        "lastTurnEndedAt": { "type": ["string", "null"] },
        "lastObservedAt": { "type": ["string", "null"] },
        "runtimeSurface": { "enum": ["unknown", "cli-tui", "desktop-app-server"] },
        "caveat": { "type": "string" }
      }
    },
    "overlays": {
      "type": "object",
      "required": ["project", "user"],
      "properties": {
        "project": { "type": "object" },
        "user": { "type": "object" }
      }
    }
  }
}
