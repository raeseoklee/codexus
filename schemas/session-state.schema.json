{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codexus.local/schemas/session-state.schema.json",
  "title": "Codexus Session State",
  "type": "object",
  "required": ["schemaVersion", "sessionId", "cwd", "status", "createdAt", "updatedAt", "lastCommand", "checkpoints", "verifications", "hookEvents", "linkedRunIds", "capabilities", "notifyDispatch", "overlays"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "sessionId": { "type": "string", "minLength": 1 },
    "cwd": { "type": "string", "minLength": 1 },
    "status": { "enum": ["initialized"] },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "lastCommand": { "type": ["string", "null"] },
    "checkpoints": { "type": "array", "items": { "type": "object" } },
    "verifications": { "type": "array", "items": { "type": "object" } },
    "hookEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "event", "observedAt", "source", "cwd", "runtimeSurface", "process"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "event": { "type": "string", "minLength": 1 },
          "observedAt": { "type": "string" },
          "source": { "enum": ["notify"] },
          "cwd": { "type": "string" },
          "runtimeSurface": { "enum": ["unknown", "cli-tui", "desktop-app-server"] },
          "process": {
            "type": "object",
            "required": ["pid", "ppid", "cwd", "bundleIdentifier"],
            "properties": {
              "pid": { "type": "number" },
              "ppid": { "type": "number" },
              "cwd": { "type": "string" },
              "bundleIdentifier": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "linkedRunIds": { "type": "array", "items": { "type": "string" } },
    "capabilities": {
      "type": "object",
      "required": ["tmux", "hooks", "statusline"],
      "properties": {
        "tmux": { "enum": ["available", "unavailable"] },
        "hooks": { "enum": ["available", "configured", "unavailable"] },
        "statusline": { "enum": ["available", "unavailable"] }
      }
    },
    "notifyDispatch": {
      "type": "object",
      "required": ["status", "lastTurnEndedAt", "lastObservedAt", "runtimeSurface", "caveat"],
      "properties": {
        "status": { "enum": ["observed", "unobserved", "not_configured"] },
        "lastTurnEndedAt": { "type": ["string", "null"] },
        "lastObservedAt": { "type": ["string", "null"] },
        "runtimeSurface": { "enum": ["unknown", "cli-tui", "desktop-app-server"] },
        "caveat": { "type": "string" }
      }
    },
    "overlays": {
      "type": "object",
      "required": ["project", "user"],
      "properties": {
        "project": { "type": "object" },
        "user": { "type": "object" }
      }
    }
  }
}
