{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codexus.local/schemas/automation-recovery.schema.json",
  "title": "Codexus Automation Recovery Projection",
  "type": "object",
  "properties": {
    "schemaVersion": { "const": 1 },
    "stability": { "const": "experimental" },
    "type": { "const": "codexus.automation.recovery" },
    "feature": { "enum": ["cron", "gateway"] },
    "recordedAt": { "type": "string", "minLength": 1 },
    "dispatchStore": { "type": "object" },
    "scheduler": {
      "type": "object",
      "properties": {
        "status": { "const": "foreground_dispatch_only" },
        "queueOwned": { "const": false },
        "unattendedOwner": { "const": false },
        "mutatesScheduler": { "const": false },
        "recoveryAuthority": { "const": false },
        "completionAuthority": { "const": false }
      },
      "required": ["status", "queueOwned", "unattendedOwner", "mutatesScheduler", "recoveryAuthority", "completionAuthority"]
    },
    "ownership": {
      "type": "object",
      "properties": {
        "schemaVersion": { "const": 1 },
        "contractVersion": { "const": "automation-scheduler-ownership-v1" },
        "feature": { "enum": ["cron", "gateway"] },
        "status": { "const": "not_owned" },
        "dispatchStorePath": { "type": "string", "minLength": 1 },
        "dispatchRecordCount": { "type": "number" },
        "queue": {
          "type": "object",
          "properties": {
            "owned": { "const": false },
            "durableQueue": { "const": false },
            "path": { "type": ["string", "null"] },
            "reason": { "type": "string", "minLength": 1 }
          },
          "required": ["owned", "durableQueue", "path", "reason"]
        },
        "lease": {
          "type": "object",
          "properties": {
            "supported": { "const": false },
            "active": { "const": false },
            "ownerId": { "type": ["string", "null"] },
            "heartbeat": { "const": false },
            "reason": { "type": "string", "minLength": 1 }
          },
          "required": ["supported", "active", "ownerId", "heartbeat", "reason"]
        },
        "unattendedRetry": {
          "type": "object",
          "properties": {
            "supported": { "const": false },
            "automaticRetry": { "const": false },
            "requires": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "required": ["supported", "automaticRetry", "requires"]
        },
        "authority": {
          "type": "object",
          "properties": {
            "schedulerAuthority": { "const": false },
            "retryAuthority": { "const": false },
            "cleanupAuthority": { "const": false },
            "healthAuthority": { "const": false },
            "completionAuthority": { "const": false }
          },
          "required": ["schedulerAuthority", "retryAuthority", "cleanupAuthority", "healthAuthority", "completionAuthority"]
        }
      },
      "required": ["schemaVersion", "contractVersion", "feature", "status", "dispatchStorePath", "dispatchRecordCount", "queue", "lease", "unattendedRetry", "authority"]
    },
    "retry": {
      "type": "object",
      "properties": {
        "automaticRetry": { "const": false },
        "retryAuthority": { "const": false },
        "manualReviewRequired": { "type": "boolean" },
        "candidateCount": { "type": "number" }
      },
      "required": ["automaticRetry", "retryAuthority", "manualReviewRequired", "candidateCount"]
    },
    "recovery": {
      "type": "object",
      "properties": {
        "status": { "enum": ["no_dispatches", "manual_review_required", "clear"] },
        "candidates": { "type": "array" },
        "manualReviewCandidates": { "type": "array" },
        "unreadableArtifacts": { "type": "array" },
        "cleanupAuthority": { "const": false },
        "healthAuthority": { "const": false },
        "completionAuthority": { "const": false }
      },
      "required": ["status", "candidates", "manualReviewCandidates", "unreadableArtifacts", "cleanupAuthority", "healthAuthority", "completionAuthority"]
    },
    "authority": {
      "type": "object",
      "properties": {
        "schedulerAuthority": { "const": false },
        "retryAuthority": { "const": false },
        "cleanupAuthority": { "const": false },
        "healthAuthority": { "const": false },
        "completionAuthority": { "const": false }
      },
      "required": ["schedulerAuthority", "retryAuthority", "cleanupAuthority", "healthAuthority", "completionAuthority"]
    },
    "path": { "type": ["string", "null"] }
  },
  "required": ["schemaVersion", "stability", "type", "feature", "recordedAt", "dispatchStore", "scheduler", "retry", "recovery", "authority", "path"]
}
