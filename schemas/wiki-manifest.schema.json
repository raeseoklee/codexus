{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codexus.local/schemas/wiki-manifest.schema.json",
  "title": "Codexus Wiki Manifest",
  "type": "object",
  "properties": {
    "schemaVersion": { "const": 1 },
    "stability": { "const": "experimental" },
    "type": { "const": "codexus.wiki.manifest" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "cwd": { "type": "string", "minLength": 1 },
    "mode": { "const": "deterministic" },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "schemaVersion": { "const": 1 },
          "stability": { "const": "experimental" },
          "type": { "const": "codexus.wiki.page" },
          "pageId": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "generatedAt": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sourceRefs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "localLinks": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "sourceFingerprint": { "type": "string", "minLength": 1 },
          "freshness": { "enum": ["fresh", "stale", "partial", "unknown"] },
          "claimClasses": {
            "type": "object",
            "properties": {
              "derivableFacts": { "type": "number", "minimum": 0 },
              "advisoryClaims": { "type": "number", "minimum": 0 }
            },
            "required": ["derivableFacts", "advisoryClaims"]
          }
        },
        "required": ["schemaVersion", "stability", "type", "pageId", "title", "generatedAt", "path", "sourceRefs", "localLinks", "sourceFingerprint", "freshness", "claimClasses"]
      }
    }
  },
  "required": ["schemaVersion", "stability", "type", "generatedAt", "cwd", "mode", "pages"]
}
