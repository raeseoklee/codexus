{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codexus.local/schemas/wiki-advisory.schema.json",
  "title": "Codexus Wiki Advisory Synthesis",
  "type": "object",
  "properties": {
    "schemaVersion": { "const": 1 },
    "stability": { "const": "experimental" },
    "command": { "const": "wiki build" },
    "cwd": { "type": "string", "minLength": 1 },
    "mode": { "const": "advisory" },
    "advisoryManifestPath": { "type": "string", "minLength": 1 },
    "sourceManifestPath": { "type": "string", "minLength": 1 },
    "sourcePages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pageId": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "freshness": { "enum": ["fresh", "stale", "partial", "unknown"] },
          "sourceFingerprint": { "type": "string", "minLength": 1 }
        },
        "required": ["pageId", "title", "path", "freshness", "sourceFingerprint"]
      }
    },
    "synthesis": {
      "type": "object",
      "properties": {
        "driver": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "const": "local-deterministic" },
            "model": { "type": ["string", "null"] },
            "modelInvoked": { "const": false }
          },
          "required": ["id", "kind", "model", "modelInvoked"]
        },
        "sourceBundleHash": { "type": "string", "minLength": 1 },
        "advisoryText": { "type": "string", "minLength": 1 },
        "claimClasses": {
          "type": "object",
          "properties": {
            "derivableFacts": { "type": "number", "minimum": 0 },
            "advisoryClaims": { "type": "number", "minimum": 0 }
          },
          "required": ["derivableFacts", "advisoryClaims"]
        },
        "eligibleForAutomaticInjection": { "const": false },
        "sourceTruth": { "const": false },
        "completionAuthority": { "const": false }
      },
      "required": ["driver", "sourceBundleHash", "advisoryText", "claimClasses", "eligibleForAutomaticInjection", "sourceTruth", "completionAuthority"]
    },
    "check": {
      "type": "object",
      "properties": {
        "status": { "const": "pass" },
        "gate": { "enum": ["not_requested", "passed"] }
      },
      "required": ["status", "gate"]
    },
    "completionAuthority": { "const": false }
  },
  "required": ["schemaVersion", "stability", "command", "cwd", "mode", "advisoryManifestPath", "sourceManifestPath", "sourcePages", "synthesis", "check", "completionAuthority"]
}
