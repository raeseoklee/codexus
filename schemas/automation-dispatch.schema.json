{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codexus.local/schemas/automation-dispatch.schema.json",
  "title": "Codexus Automation Dispatch Record",
  "type": "object",
  "properties": {
    "schemaVersion": { "const": 1 },
    "dispatchId": { "type": "string", "minLength": 1 },
    "recordedAt": { "type": "string", "minLength": 1 },
    "plan": {
      "type": "object",
      "properties": {
        "actionAuthority": {
          "type": "object",
          "properties": {
            "schemaVersion": { "const": 1 },
            "contractVersion": { "const": "automation-action-authority-v1" },
            "feature": { "enum": ["cron", "gateway"] },
            "actionSurface": { "enum": ["cron.run-now", "gateway.check"] },
            "mode": { "enum": ["dry-run", "live"] },
            "sideEffects": {
              "type": "object",
              "properties": {
                "startsRun": { "type": "boolean" },
                "mutatesScheduler": { "const": false },
                "mutatesGatewayListener": { "const": false },
                "requiresLock": { "type": "boolean" },
                "requiresExplicitApproval": { "type": "boolean" }
              },
              "required": ["startsRun", "mutatesScheduler", "mutatesGatewayListener", "requiresLock", "requiresExplicitApproval"]
            },
            "dispatcherAuthority": { "enum": ["none", "linked_codexus_run"] },
            "runOutcomeSource": { "type": ["string", "null"] },
            "cleanupAuthority": { "const": false },
            "healthAuthority": { "const": false },
            "completionAuthority": { "const": false },
            "caveat": { "type": "string", "minLength": 1 }
          },
          "required": ["schemaVersion", "contractVersion", "feature", "actionSurface", "mode", "sideEffects", "dispatcherAuthority", "runOutcomeSource", "cleanupAuthority", "healthAuthority", "completionAuthority", "caveat"]
        }
      },
      "required": ["actionAuthority"]
    },
    "ledgerEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "dryRun": { "const": false },
          "payload": { "type": "object" }
        },
        "required": ["type", "dryRun"]
      }
    },
    "path": { "type": "string", "minLength": 1 }
  },
  "required": ["schemaVersion", "dispatchId", "recordedAt", "plan", "ledgerEvents", "path"]
}
