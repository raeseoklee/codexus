{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codexus.local/schemas/supply-chain-policy.schema.json",
  "title": "Codexus Supply Chain Policy",
  "type": "object",
  "properties": {
    "runtimeDependenciesMax": { "type": "integer", "minimum": 0 },
    "allowedLifecycleScripts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowedDevDependencyInstallScripts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowRuntimeNetworkImports": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "forbiddenPackageFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "requiredPackageFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "binTargetsMustBeBuiltArtifacts": { "type": "boolean" },
    "lockfileIntegrityRequired": { "type": "boolean" }
  }
}
